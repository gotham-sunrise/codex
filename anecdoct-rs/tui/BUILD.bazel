load("//:defs.bzl", "MACOS_WEBRTC_RUSTC_LINK_FLAGS", "anecdoct_rust_crate")

anecdoct_rust_crate(
    name = "tui",
    crate_name = "anecdoct_tui",
    compile_data = glob(
        include = ["**"],
        exclude = [
            "**/* *",
            "BUILD.bazel",
            "Cargo.toml",
        ],
        allow_empty = True,
    ) + [
        "//anecdoct-rs/collaboration-mode-templates:templates/default.md",
        "//anecdoct-rs/collaboration-mode-templates:templates/plan.md",
    ],
    test_data_extra = glob([
        "src/**/*.rs",
        "src/**/snapshots/**",
    ]),
    integration_compile_data_extra = ["src/test_backend.rs"],
    extra_binaries = [
        "//anecdoct-rs/cli:anecdoct",
    ],
    rustc_flags_extra = MACOS_WEBRTC_RUSTC_LINK_FLAGS,
    test_shard_counts = {
        "tui-unit-tests": 8,
    },
)
